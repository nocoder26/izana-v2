# ═══════════════════════════════════════════════════
# IZANA BACKEND ENVIRONMENT VARIABLES
# Copy to .env and fill in actual values
# ═══════════════════════════════════════════════════

# ── Supabase ──
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# ── Groq (LLM inference) ──
GROQ_API_KEY=gsk_...primary-key
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_MAX_CONCURRENT_REQUESTS=10

# ── OpenAI (embeddings only) ──
OPENAI_API_KEY=sk-...

# ── Admin ──
ADMIN_API_KEY=your-64-char-hex-string
NUTRITIONIST_JWT_SECRET=your-separate-64-char-hex-string

# ── Redis (Decision 2 — REQUIRED) ──
REDIS_URL=redis://localhost:6379

# ── Frontend ──
FRONTEND_URL=http://localhost:3000

# ── Email (optional) ──
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@izana.ai

# ── Cloudflare Stream (optional until Stage 15) ──
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

# ── Feature Flags (Decision 11) ──
FEATURE_BLOODWORK_ENABLED=true
FEATURE_PARTNER_ENABLED=true
FEATURE_FIE_ENABLED=false
FEATURE_PUSH_ENABLED=true

# ── FIE ──
FIE_ANONYMIZATION_SALT=
FIE_MIN_CYCLES_FOR_INSIGHTS=50

# ── Admin Dashboard ──
NEXT_PUBLIC_ADMIN_EMAIL=admin@izana.com

# ── App ──
ENVIRONMENT=development
DEBUG=true
